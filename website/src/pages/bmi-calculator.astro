---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "Free GLP-1 Eligibility Calculator | BMI Check — LDRGLPRx";
const description = "Free BMI calculator and GLP-1 eligibility checker. Find out if you qualify for semaglutide or tirzepatide weight loss medication with our instant assessment tool.";
const canonical = "https://ldrglprx.com/bmi-calculator.html";
const keywords = "GLP-1 eligibility calculator, BMI calculator weight loss, semaglutide eligibility, tirzepatide eligibility, weight loss medication calculator, BMI check GLP-1, am I eligible for GLP-1";
const ogImage = "https://ldrglprx.com/images/og-bmi-calculator.jpg";
const robots = "index, follow";
---
<BaseLayout title={title} description={description} canonical={canonical} keywords={keywords} ogImage={ogImage} robots={robots}>
